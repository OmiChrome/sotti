# Copy this file to .env and fill in your values.
# .env is git-ignored; .env.example is committed.

GEMINI_API_KEY=your_key_here
# GEMINI_API_KEY_FALLBACK=your_fallback_key_here   # optional

# OCR_MODEL: vision model that reads image packs → writes question.md
OCR_MODEL=gemma-4-31b-it

# ORCHESTRATOR_MODEL: classifies images (new question vs debug), guides CODE_MODEL
ORCHESTRATOR_MODEL=gemma-4-31b-it

# CODE_MODEL: generates + iteratively fixes Java solutions
CODE_MODEL=gemma-4-31b-it

WATCH_DIR="C:\Users\omi\Pictures\Screenshots"
SETTLE_SECONDS=20

# Optional Server Bindings (Defaults: 0.0.0.0 : 8000)
# SERVER_HOST="0.0.0.0"
# SERVER_PORT=8000
